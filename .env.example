# ─────────────────────────────────────────────
# LangGraph Agent Patterns — Environment Config
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Ollama Model Settings ──────────────────────
OLLAMA_MODEL=llama3.1:latest
OLLAMA_EMBEDDING_MODEL=mxbai-embed-large
OLLAMA_TEMPERATURE=0.8
OLLAMA_NUM_PREDICT=256

# Set to false when running tests without Ollama running
OLLAMA_VALIDATE_ON_INIT=true

# ── RAG Agent Settings ─────────────────────────
# Full path to your PDF document
PDF_PATH=C:\Users\<your_username>\Downloads\your_document.pdf

# Directory where Chroma will persist the vector store
CHROMA_PERSIST_DIR=./db

# Name of the Chroma collection
CHROMA_COLLECTION=document_content

# Number of chunks to retrieve per query
RETRIEVER_K=5

# Chunk size and overlap for text splitting
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ── LangSmith Tracing (optional) ───────────────
# Set to true to enable LangSmith tracing
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=langgraph-agent-patterns
